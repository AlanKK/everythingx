    "version": "0.2.0",
    "configurations": [
    {
        "name": "Launch app",
        "type": "go",
        "request": "launch",
        "mode": "debug",
        "program": "${workspaceFolder}/cmd/everythingx",
    },
    {
        "name": "Launch command-line",
        "type": "go",
        "request": "launch",
        "mode": "debug",
        "program": "${workspaceFolder}/cmd/everythingx",
        "args": ["-name=alan"],
    },
    {
        "name": "Launch service",
        "type": "go",
        "request": "launch",
        "mode": "debug",
        "program": "${workspaceFolder}/cmd/service/findfilesd",
        "args": ["--db_path", "/Users/alan/Downloads/files.db"]   
    },
    {
        "name": "Launch e2e test",
        "type": "go",
        "request": "launch",
        "mode": "debug",
        "program": "${workspaceFolder}/e2eTest/main",
        "args": ["--monitor_path", "/Users/alan/Documents/git/findfiles/e2eTest/findfiles_test", "--db_path", "/Users/alan/Documents/git/findfiles/data/files.db"]   
    }]
}