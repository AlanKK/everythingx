{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

    {
        "name": "Launch app",
        "type": "go",
        "request": "launch",
        "mode": "debug",
        "program": "${workspaceFolder}/cmd/everythingx",
    },
    {
        "name": "Launch command-line",
        "type": "go",
        "request": "launch",
        "mode": "debug",
        "program": "${workspaceFolder}/cmd/cli",
        "args": ["everythingx -b"],
    },
    {
        "name": "Launch disk-access",
        "type": "go",
        "request": "launch",
        "mode": "debug",
        "program": "${workspaceFolder}/tools/disk-access",
    },
    {
        "name": "Launch service",
        "type": "go",
        "request": "launch",
        "mode": "debug",
        "program": "${workspaceFolder}/cmd/service/main.go",
        "args": ["--monitor_path", "/Users/alan/Documents", "--db_path", "/Users/alan/Downloads/files.db"]   
    },
    {
        "name": "Launch e2e test",
        "type": "go",
        "request": "launch",
        "mode": "debug",
        "program": "${workspaceFolder}/e2eTest/main.go",
        "args": ["--monitor_path", "/Users/alan/Documents/git/everythingx/e2eTest/everythingx_test", "--db_path", "/Users/alan/Documents/git/everythingx/data/files.db"]   
    }]
}